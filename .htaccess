<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow access to files and directories that actually exist (assets, fpdf, pdfs, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Map everything else to index.php?route=$1
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>
