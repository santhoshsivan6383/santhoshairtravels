<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /santhoshairtravels/

    # Allow access to assets, fpdf, pdfs directories
    RewriteCond %{REQUEST_URI} ^/santhoshairtravels/(assets|fpdf|pdfs)/ [NC]
    RewriteRule ^ - [L]

    # Map everything to index.php?route=$1
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>
